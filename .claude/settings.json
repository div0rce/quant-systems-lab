{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(git switch*)",
      "Bash(git checkout*)",
      "Bash(git pull*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(gh pr*)",
      "Bash(make*)",
      "Bash(cmake*)",
      "Bash(ctest*)",
      "Bash(ninja*)",
      "Bash(clang-format*)",
      "Bash(clang-tidy*)",
      "Bash(python3*)",
      "Bash(pip*)",
      "Bash(pre-commit*)"
    ],
    "ask": [
      "Bash(git push*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(secrets/**)",
      "Bash(rm -rf /)",
      "Bash(git push origin main*)",
      "Bash(git push --force*)"
    ]
  }
}
